@model IEnumerable<MvcApp.Models.TaskObject>
@using System.Linq

@{
    ViewData["Title"] = "Задачи по статусу";
    // Группировка выполняется прямо в представлении
    var grouped = Model.GroupBy(p => p.Status).OrderBy(g => g.Key);
}

<h1>Задачи по статусу</h1>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        В базе данных нет задач. Добавьте хотя бы одну задачу через <a aspaction="Create">форму создания</a>.
    </div>
}
else
{
    <div class="accordion" id="categoriesAccordion">
        @{
            int index = 0;
        }
        @foreach (var group in grouped)
        {
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(index != 0 ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse@(index)">

                        <strong>@group.Key</strong>

                        <span class="badge bg-secondary ms-2">
                            @group.Count() задач
                        </span>
                    </button>
                </h2>
                <div id="collapse@(index)"
                     class="accordion-collapse collapse @(index == 0 ? "show" : "")"
                     data-bs-parent="#categoriesAccordion">
                    <div class="accordion-body">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Описание</th>
                                    <th>Завершено</th>
                                    <th>Дата добавления</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in group)
                                {
                                    <tr>
                                        <td>@task.Title</td>
                                        <td class="text-primary fwbold">@task.Description</td>
                                        <td>
                                            @if (task.IsCompleted)
                                            {
                                                <span class="badge bg-success">
                                                    Да
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    Нет
                                                </span>
                                            }
                                        </td>
                                        <td>@task.CreatedDate.ToShortDateString()</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-sm btn-info">Детали</a>
                                            <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-warning">Изменить</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            index++;
        }
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">← Назад к списку</a>
    <a asp-action="Create" class="btn btn-primary">Добавить новую задачу</a>
</div>

@section Scripts {
    <script>
        // Дополнительная инициализация Bootstrap аккордеона (если нужно)
        document.addEventListener('DOMContentLoaded', function () {
        // Bootstrap 5 аккордеон работает автоматически с data-bs-toggle
            console.log('Страница группировки загружена');
        });
    </script>
}
