@model IEnumerable<MvcApp.Models.Task>
@{
    ViewData["Title"] = "Управление задачами";
}

<h1>Управление задачами</h1>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<p>
    <a asp-action="Create" class="btn btn-primary">Добавить задачу</a>
    <a asp-action="NotOverDue" class="btn btn-success">Только непросроченные</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            @* Html.DisplayNameFor выводит имя свойства 
            (или то, что указано в атрибуте [Display]) *@

            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.Priority)</th>
            <th>@Html.DisplayNameFor(model => model.Assignee)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.DueDate)</th>
            <th>@Html.DisplayNameFor(model => model.IsCompleted)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td>@item.Priority</td>
                <td>@item.Assignee</td>
                <td>@item.Status</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (item.IsCompleted)
                    {
                        <span class="badge bg-success">Да</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Нет</span>
                    }
                </td>
                @* <td>@item.CreatedDate.ToShortDateString()</td> *@

                <td>
                    @* asp-action и asp-route-id генерируют правильные ссылки, 
                    например /Tasks/Edit/5 *@
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info m-1">Детали</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning m-1">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger m-1">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>