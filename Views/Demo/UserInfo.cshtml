@{

}

<h1>Информация о пользователе</h1>
<p>
    <span class="bolder-span">Имя: </span> <span>@ViewBag.name</span>
</p>
<p>
    <span class="bolder-span">Возраст: </span> <span>@ViewBag.age</span>
</p>

@if (ViewBag.IsAdult)
{
    <p>
        <span class="bolder-span">Статус: </span><span style="color: green">Совершеннолетний</span>
    </p>
}
else
{
    <p>
        <span class="bolder-span">Статус: </span><span style="color: orange;">Несовершеннолетний</span>
    </p>
}

<p>
    <span class="bolder-span">Год рождения: </span>@ViewData["BirthYear"]
</p>
<p>
    <span class="bolder-span">Текущий год: </span>@ViewData["CurrentYear"]
</p>

<style>
    .bolder-span{
        font-weight: bold;
    }
</style>

